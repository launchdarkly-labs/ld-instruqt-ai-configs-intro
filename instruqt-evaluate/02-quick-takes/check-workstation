#!/bin/sh

# Validates the learner has attached at least one built-in judge to the
# otto-born variation. We don't check sampling rate (operator-tunable).

API="https://app.launchdarkly.com/api/v2"

VAR=$(curl -fsS -X GET \
  "${API}/projects/${LD_PROJECT_KEY}/ai-configs/otto-assistant/variations/otto-born" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}" \
  -H 'LD-API-Version: beta')

JUDGE_COUNT=$(echo "$VAR" | jq -r '.judgeConfiguration.judges // [] | length')

if [ "$JUDGE_COUNT" -lt 1 ]; then
  fail-message "No judges are attached to **Otto (Born)** yet. In the LaunchDarkly UI, open the variation, find the **Judges** section, and click **Attach judges**. Pick at least one built-in (Accuracy, Relevance, or Toxicity)."
  exit 1
fi

# Soft confirmation that a BUILT-IN judge is attached (vs the learner
# accidentally adding a custom one). Built-ins have well-known metric keys.
BUILT_IN_COUNT=$(echo "$VAR" | jq -r '
  [.judgeConfiguration.judges[]? | .judgeConfigKey] as $keys
  | .judgeConfiguration.judges // []
  | length
')

# Per-judge keys aren't always returnable inline, so just trust the count.
# Operator can tighten this if needed.

exit 0
