#!/bin/sh

# Per-challenge setup for ch06 (prompt experiment).
#
# Stops the lower-rate realchat traffic and starts the higher-rate
# synthetic experiment_traffic generator instead. The experiment needs
# enough samples per variation to converge inside the lab budget; real
# Bedrock calls would be too slow and too expensive.

set -e

cd /opt/ld/ai-configs-intro/terraform/evaluate-06
echo "project_key = \"${LD_PROJECT_KEY}\"" > terraform.tfvars
terraform init -input=false

# Swap out the realchat traffic for the higher-rate synthetic generator.
# The experiment traffic evaluates otto-assistant on each loop, which means
# LD's experiment randomization fires once the experiment is started.
pkill -f realchat_traffic.py 2>/dev/null || true

if ! pgrep -f experiment_traffic.py > /dev/null; then
  nohup /opt/ld/ai-configs-intro/app/.venv/bin/python3 \
    /opt/ld/ai-configs-intro/traffic-generator/experiment_traffic.py \
    > /var/log/togglewear-experiment.log 2>&1 &
fi

exit 0
