#!/bin/sh

# Validates the prompt experiment is set up and has at least one iteration
# in progress (or completed). Promotion is checked permissively — we look
# for either a completed iteration OR the fallthrough rule having been
# changed back to a single variation post-experiment.

API="https://app.launchdarkly.com/api/v2"

# 1. The otto-recommender contender variation exists.
CONFIG=$(curl -fsS -X GET \
  "${API}/projects/${LD_PROJECT_KEY}/ai-configs/otto-assistant" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}")

CONTENDER=$(echo "$CONFIG" | jq -r '.variations[]? | select(.key=="otto-recommender") | .key // ""')
if [ -z "$CONTENDER" ]; then
  fail-message "The **Otto v4 (Recommender)** variation hasn't been created yet. On the Otto Assistant config, click **Add variation** and use the prompt from the lab."
  exit 1
fi

# 2. The otto-prompt-experiment experiment exists with at least one iteration.
EXPERIMENT=$(curl -fsS -X GET \
  "${API}/projects/${LD_PROJECT_KEY}/environments/test/experiments/otto-prompt-experiment" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}" \
  -H 'LD-API-Version: beta' 2>/dev/null || echo '{}')

EXP_KEY=$(echo "$EXPERIMENT" | jq -r '.key // ""')
if [ -z "$EXP_KEY" ]; then
  fail-message "The **otto-prompt-experiment** doesn't exist yet. On the Experiments page, click **Create experiment** with the configuration from the lab."
  exit 1
fi

# 3. At least one iteration has been started or completed.
ITERATIONS=$(echo "$EXPERIMENT" | jq -r '[.iterations // []] | flatten | length')
if [ "$ITERATIONS" -lt 1 ]; then
  fail-message "The experiment exists but no iteration has been started. From the experiment's detail page, click **Start iteration** to begin collecting data."
  exit 1
fi

exit 0
