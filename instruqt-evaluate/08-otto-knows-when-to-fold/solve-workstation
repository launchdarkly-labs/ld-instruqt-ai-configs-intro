#!/bin/sh

# Apply the adaptive-switching end-state: TF flips fallthrough to stiff,
# patch-server installs adaptive.py + the import + the observe call, and
# realchat traffic is started so the loop has scores to react to. The
# loop then flips the fallthrough back to otto-born within ~60-90s.

set -e

cd /opt/ld/ai-configs-intro/terraform/evaluate-08
terraform apply -auto-approve

python3 /opt/ld/ai-configs-intro/terraform/evaluate-08/patch-server.py
service togglewear restart

pkill -f background_traffic.py 2>/dev/null || true
pkill -f experiment_traffic.py 2>/dev/null || true
if ! pgrep -f realchat_traffic.py > /dev/null; then
  nohup /opt/ld/ai-configs-intro/app/.venv/bin/python3 \
    /opt/ld/ai-configs-intro/traffic-generator/realchat_traffic.py \
    > /var/log/togglewear-realchat.log 2>&1 &
fi

exit 0
