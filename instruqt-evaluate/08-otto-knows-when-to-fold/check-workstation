#!/bin/sh

# Validates the adaptive switching wiring AND that it actually fired.
#
# Three assertions:
#   1. /opt/ld/ai-configs-intro/app/adaptive.py exists.
#   2. server.py imports adaptive_observe and invokes it with score.
#   3. The fallthrough is currently set to otto-born (the loop flipped
#      back from the stiff state setup put it in). Soft on this — also
#      passes if the learner manually reset it.

API="https://app.launchdarkly.com/api/v2"

if [ ! -f /opt/ld/ai-configs-intro/app/adaptive.py ]; then
  fail-message "The **adaptive.py** module isn't in the app directory yet. Create it from the lab content."
  exit 1
fi

if ! grep -q 'from adaptive import observe as adaptive_observe' /opt/ld/ai-configs-intro/app/server.py; then
  fail-message "**server.py** doesn't import the adaptive module yet. Add \`from adaptive import observe as adaptive_observe\` to the imports."
  exit 1
fi

if ! grep -q 'adaptive_observe(score)' /opt/ld/ai-configs-intro/app/server.py; then
  fail-message "**server.py** isn't calling \`adaptive_observe(score)\` after the brand-voice judge emits a score. Paste the one-line invocation from the lab."
  exit 1
fi

# Soft check: confirm the loop actually flipped the fallthrough back to
# otto-born. If it hasn't, the wiring may be correct but not enough
# samples have accumulated yet — tell the learner to give it another
# minute.
TARGETING=$(curl -fsS -X GET \
  "${API}/projects/${LD_PROJECT_KEY}/ai-configs/otto-assistant/targeting" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}")

FALL_VAR=$(echo "$TARGETING" | jq -r '.environments.test.fallthrough.variation // empty')
BORN_VAR=$(echo "$TARGETING" | jq -r '[.variations[]? | select(.key=="otto-born")] | .[0]._id // empty')

if [ -z "$FALL_VAR" ] || [ -z "$BORN_VAR" ] || [ "$FALL_VAR" != "$BORN_VAR" ]; then
  fail-message "Your adaptive loop hasn't flipped the fallthrough back to **otto-born** yet. Give the realchat traffic another minute to accumulate samples below threshold, or check the log: \`tail -f /var/log/togglewear-realchat.log\`."
  exit 1
fi

exit 0
