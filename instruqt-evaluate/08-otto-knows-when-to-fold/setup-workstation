#!/bin/sh

# Per-challenge setup for ch08 (adaptive switching).
#
# Applies the evaluate-08 module, which flips Otto's fallthrough to
# otto-stiff so real /chat traffic gets the off-brand variation and
# the brand-voice judge starts scoring it low. Then swaps in the
# realchat traffic generator so the judge actually fires.
#
# The learner's job is to wire the adaptive loop in server.py; once
# they do, the loop sees the low scores accumulating and flips the
# fallthrough back to otto-born.

set -e

cd /opt/ld/ai-configs-intro/terraform/evaluate-08
echo "project_key = \"${LD_PROJECT_KEY}\"" > terraform.tfvars
terraform init -input=false
terraform apply -auto-approve

# Swap to realchat traffic so the brand-voice judge sees real Otto
# responses to score.
pkill -f background_traffic.py 2>/dev/null || true
pkill -f experiment_traffic.py 2>/dev/null || true

if ! pgrep -f realchat_traffic.py > /dev/null; then
  nohup /opt/ld/ai-configs-intro/app/.venv/bin/python3 \
    /opt/ld/ai-configs-intro/traffic-generator/realchat_traffic.py \
    > /var/log/togglewear-realchat.log 2>&1 &
fi

exit 0
