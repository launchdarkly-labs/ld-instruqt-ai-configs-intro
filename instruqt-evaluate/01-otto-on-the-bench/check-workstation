#!/bin/sh

# Validates the learner has run an offline evaluation against the seeded
# customer-questions dataset.
#
# Two assertions:
#   1. The customer-questions dataset exists.
#   2. At least one evaluation has at least one completed run.

API="https://app.launchdarkly.com/api/v2"

DATASETS=$(curl -fsS -X GET \
  "${API}/projects/${LD_PROJECT_KEY}/datasets" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}" \
  -H 'LD-API-Version: beta')

DATASET_ID=$(echo "$DATASETS" | jq -r '.items[]? | select(.filename == "customer-questions.jsonl") | .id' | head -n 1)

if [ -z "$DATASET_ID" ] || [ "$DATASET_ID" = "null" ]; then
  fail-message "The customer-questions dataset is missing from your project. The track setup should have uploaded it — try running the **Skip** button if it didn't seed."
  exit 1
fi

EVALUATIONS=$(curl -fsS -X GET \
  "${API}/projects/${LD_PROJECT_KEY}/evaluations" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}" \
  -H 'LD-API-Version: beta')

EVAL_COUNT=$(echo "$EVALUATIONS" | jq -r '.items // [] | length')
if [ "$EVAL_COUNT" -lt 1 ]; then
  fail-message "You haven't created an evaluation yet. In the LaunchDarkly UI, go to **Evaluations**, click **Create evaluation**, point it at the **customer-questions** dataset and the **otto-born** variation."
  exit 1
fi

# Walk evaluations looking for at least one completed run.
EVAL_IDS=$(echo "$EVALUATIONS" | jq -r '.items[]? | .id')
FOUND_COMPLETED_RUN=0
for ID in $EVAL_IDS; do
  RUNS=$(curl -fsS -X GET \
    "${API}/projects/${LD_PROJECT_KEY}/evaluations/${ID}/runs" \
    -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}" \
    -H 'LD-API-Version: beta')
  COMPLETED=$(echo "$RUNS" | jq -r '[.items[]? | select((.status // .state) == "completed")] | length')
  if [ "$COMPLETED" -gt 0 ]; then
    FOUND_COMPLETED_RUN=1
    break
  fi
done

if [ "$FOUND_COMPLETED_RUN" -ne 1 ]; then
  fail-message "Your evaluation hasn't completed a run yet. From the evaluation's detail page, click **Run evaluation** and wait for it to finish (usually under a minute)."
  exit 1
fi

exit 0
