#!/bin/sh

# Per-challenge setup for ch07 (guarded rollout).
#
# Applies the evaluate-07 module (adds the Nova Pro Stiff variation) and
# swaps in the long-running background_traffic.py so the rollout has
# organic data flowing while the learner configures it. Background traffic
# emits otto-brand-voice-score events biased per model — Stiff scores
# low, so the guarded rollout's regression detection fires once a
# meaningful fraction of traffic hits the Stiff variation.

set -e

cd /opt/ld/ai-configs-intro/terraform/evaluate-07
echo "project_key = \"${LD_PROJECT_KEY}\"" > terraform.tfvars
terraform init -input=false
terraform apply -auto-approve

# Stop any prior traffic generators; start background_traffic.py.
pkill -f experiment_traffic.py 2>/dev/null || true
pkill -f realchat_traffic.py 2>/dev/null || true

if ! pgrep -f background_traffic.py > /dev/null; then
  nohup /opt/ld/ai-configs-intro/app/.venv/bin/python3 \
    /opt/ld/ai-configs-intro/traffic-generator/background_traffic.py \
    > /var/log/togglewear-bg-traffic.log 2>&1 &
fi

exit 0
