#!/bin/sh

# Validates the learner has set up the guarded rollout.
#
# Three assertions:
#   1. The otto-stiff Nova Pro variation exists (setup-workstation creates
#      it; we re-check in case the learner deleted it).
#   2. otto-assistant's evaluationMetricKey points at otto-brand-voice-score
#      (set by ch03; double-checked here for the rollout to make sense).
#   3. A guarded rollout (or at least a rollout structure) is configured on
#      the test environment's fallthrough — permissive proxy for "rollout
#      configured."

API="https://app.launchdarkly.com/api/v2"

CONFIG=$(curl -fsS -X GET \
  "${API}/projects/${LD_PROJECT_KEY}/ai-configs/otto-assistant" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}")

STIFF=$(echo "$CONFIG" | jq -r '.variations[]? | select(.key=="otto-stiff") | .modelConfigKey // ""')
if [ -z "$STIFF" ]; then
  fail-message "The **Otto v4 (Stiff)** Nova Pro variation hasn't been created. Re-run setup, or use the **Skip** button if setup isn't working."
  exit 1
fi
if [ "$STIFF" != "Amazon.nova-pro" ]; then
  fail-message "Otto v4 (Stiff) isn't using Amazon Nova Pro. Expected modelConfigKey **Amazon.nova-pro**, got **${STIFF}**."
  exit 1
fi

EVAL_KEY=$(echo "$CONFIG" | jq -r '.evaluationMetricKey // ""')
if [ "$EVAL_KEY" != "otto-brand-voice-score" ]; then
  fail-message "Otto's evaluationMetricKey isn't wired to **otto-brand-voice-score**. Was Challenge 03 completed? The guarded rollout needs a metric to watch."
  exit 1
fi

TARGETING=$(curl -fsS -X GET \
  "${API}/projects/${LD_PROJECT_KEY}/ai-configs/otto-assistant/targeting" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}")

HAS_ROLLOUT=$(echo "$TARGETING" | jq -r '.environments.test.fallthrough.rollout // empty')
if [ -z "$HAS_ROLLOUT" ]; then
  fail-message "No guarded rollout configured on the test environment's default rule. On the **Targeting** tab, click the default rule and choose **Start guarded rollout** with the **otto-brand-voice-score** metric."
  exit 1
fi

exit 0
