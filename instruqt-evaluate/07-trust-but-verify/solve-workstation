#!/bin/sh
#
# Skip path for ch07. Re-applies the evaluate-07 module (Nova Pro + Stiff
# variation), makes sure background traffic is running, and falls back to
# a plain percentage-rollout on the fallthrough so the check's "rollout
# configured" proxy passes. Note: this isn't a real GUARDED rollout — the
# learner-driven UI flow is. See ../../PHASES-evaluate.md Phase 6 for the
# start-guarded-rollout REST surface if a future revision wants to
# automate it.

set -e

cd /opt/ld/ai-configs-intro/terraform/evaluate-07
terraform apply -auto-approve

# Background traffic.
pkill -f experiment_traffic.py 2>/dev/null || true
pkill -f realchat_traffic.py 2>/dev/null || true
if ! pgrep -f background_traffic.py > /dev/null; then
  nohup /opt/ld/ai-configs-intro/app/.venv/bin/python3 \
    /opt/ld/ai-configs-intro/traffic-generator/background_traffic.py \
    > /var/log/togglewear-bg-traffic.log 2>&1 &
fi

# Percentage-rollout fallback so the check's proxy passes.
STIFF_VAR_ID=$(curl -s -X GET \
  "https://app.launchdarkly.com/api/v2/projects/${LD_PROJECT_KEY}/ai-configs/otto-assistant/targeting" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}" \
  | jq -r '.variations[]? | select(.name=="Otto v4 (Stiff)") | ._id')
BORN_VAR_ID=$(curl -s -X GET \
  "https://app.launchdarkly.com/api/v2/projects/${LD_PROJECT_KEY}/ai-configs/otto-assistant/targeting" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}" \
  | jq -r '.variations[]? | select(.name=="Otto v1 (Born)") | ._id')

if [ -n "$STIFF_VAR_ID" ] && [ -n "$BORN_VAR_ID" ]; then
  curl -fsS -X PATCH \
    "https://app.launchdarkly.com/api/v2/projects/${LD_PROJECT_KEY}/ai-configs/otto-assistant/targeting" \
    -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}" \
    -H 'Content-Type: application/json; domain-model=launchdarkly.semanticpatch' \
    --data-raw "$(jq -n --arg stiff "$STIFF_VAR_ID" --arg born "$BORN_VAR_ID" '
      {
        environmentKey: "test",
        instructions: [{
          kind: "updateFallthroughVariationOrRollout",
          rolloutWeights: { ($stiff): 10000, ($born): 90000 },
          rolloutContextKind: "user"
        }]
      }')" \
    || echo "(rollout REST call failed — learner can configure in UI)"
fi

exit 0
