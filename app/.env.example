# ToggleWear — environment variables (BYO-credentials variant).
#
# You bring your own LaunchDarkly project + AWS Bedrock access. The Welcome
# challenge walks you through it:
#   1. In the LaunchDarkly tab, create a project (it comes with a Test env).
#   2. Copy its Test-environment SDK key and the project key.
#   3. Create a Writer API access token (Account settings -> Authorization).
#   4. Paste all of them + your AWS creds below, save, and click Check.

# --- LaunchDarkly (from the project you create in the UI) ---
# Test-environment SDK key: Project settings -> Environments -> Test.
LD_SDK_KEY=
# Your project's key.
LD_PROJECT_KEY=
# API access token, role = Writer (Account settings -> Authorization ->
# Access tokens). Powers the "Check" buttons.
LAUNCHDARKLY_ACCESS_TOKEN=

# --- AWS Bedrock (Claude + Nova access in US regions) ---
# Long-lived IAM user keys recommended — temporary/SSO creds expire mid-session.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: ONLY if you use temporary/SSO (STS) credentials.
AWS_SESSION_TOKEN=
# Leave as us-east-1 — the app calls US cross-region model profiles.
AWS_REGION=us-east-1

# Hard cap on chat turns per session (cost protection).
LD_CHAT_TURN_LIMIT=30
