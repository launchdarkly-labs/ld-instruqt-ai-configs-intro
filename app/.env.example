# ToggleWear — environment variables.
#
# In THIS variant of the workshop you bring your OWN credentials. The Welcome
# challenge walks you through it. Short version:
#
#   1. Open this file (app/.env) in the Code Editor.
#   2. Fill in the values under "FILL THESE IN" below.
#   3. Save, then click Check on the Welcome challenge — it creates your
#      LaunchDarkly project and fills in LD_SDK_KEY / LD_PROJECT_KEY for you.

# ============================= FILL THESE IN =============================
# LaunchDarkly API access token. In LaunchDarkly: Account settings ->
# Authorization -> Access tokens -> Create token, role = Writer (or higher).
# Used to create your project and to power the "Check" buttons.
LAUNCHDARKLY_ACCESS_TOKEN=

# AWS credentials with Bedrock access (Claude + Nova models). Long-lived IAM
# user keys are recommended — temporary/SSO creds expire mid-session.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: ONLY if you use temporary/SSO (STS) credentials. Leave blank for
# long-lived IAM user keys.
AWS_SESSION_TOKEN=
# Leave this as us-east-1 — the app calls US cross-region model profiles.
AWS_REGION=us-east-1
# =========================================================================

# ====================== AUTO-FILLED — leave blank ========================
# The Welcome Check fills these in after creating your project. Don't edit.
LD_SDK_KEY=
LD_PROJECT_KEY=
# =========================================================================

# Hard cap on chat turns per session (cost protection). When exceeded, /chat
# returns a graceful "demo limit reached" message instead of calling the model.
LD_CHAT_TURN_LIMIT=30
