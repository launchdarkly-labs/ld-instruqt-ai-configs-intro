# ToggleWear — environment variables.
#
# At image bake time, this file is copied to `.env`. At Instruqt lab start, the
# track-level setup-workstation `sed`s real values into `.env`. For local
# development, copy this file to `.env` and fill in your own values.

# --- LaunchDarkly ---
# Server-side SDK key for the student's project (env: test).
LD_SDK_KEY=
# Client-side environment ID (rarely used by this app; included for parity with
# the reference track and for any future frontend flag usage).
LD_CLIENT_KEY=
# Project key, e.g. "ai-configs-intro-<sandbox-id>".
LD_PROJECT_KEY=

# --- AWS Bedrock ---
# Used by Phase 3+ for LLM calls. Phase 2 doesn't read these but they're
# included now so the image's seeded .env has the full surface area.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- Cost-protection knobs ---
# Hard cap on chat turns per session. When exceeded, /chat returns a
# graceful "demo limit reached" message instead of calling the model.
# Default of 30 is sized for a learner who chats with Otto across most labs
# without spamming. Tune down if real-world usage shows it's too generous.
LD_CHAT_TURN_LIMIT=30
