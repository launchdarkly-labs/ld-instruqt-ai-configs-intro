#!/bin/bash
#
# Welcome Check (BYO-credentials variant). The learner CREATES their own
# LaunchDarkly project in the UI, then pastes its SDK key + project key, a
# Writer API token, and their AWS credentials into app/.env. This Check:
#   1. validates the pasted values + that the token/project are real,
#   2. exports the token + project key to the shell profiles so every later
#      challenge's check/setup/solve script can authenticate,
#   3. restarts the app, and
#   4. smoke-tests Bedrock so a missing model grant fails HERE, not in ch01.
set -o pipefail

REPO=/opt/ld/ai-configs-intro
APP_ENV="$REPO/app/.env"
VENV="$REPO/app/.venv"
HAIKU="us.anthropic.claude-haiku-4-5-20251001-v1:0"

# Load whatever the learner has pasted into .env.
set -a
[ -f "$APP_ENV" ] && . "$APP_ENV"
set +a

# 1. Require the learner-supplied values.
missing=""
[ -z "${LD_SDK_KEY:-}" ]                && missing="$missing LD_SDK_KEY"
[ -z "${LD_PROJECT_KEY:-}" ]            && missing="$missing LD_PROJECT_KEY"
[ -z "${LAUNCHDARKLY_ACCESS_TOKEN:-}" ] && missing="$missing LAUNCHDARKLY_ACCESS_TOKEN"
[ -z "${AWS_ACCESS_KEY_ID:-}" ]         && missing="$missing AWS_ACCESS_KEY_ID"
[ -z "${AWS_SECRET_ACCESS_KEY:-}" ]     && missing="$missing AWS_SECRET_ACCESS_KEY"
if [ -n "$missing" ]; then
  fail-message "Fill in **app/.env** in the Code Editor and save, then click Check again. Missing:${missing}"
  exit 1
fi

# 2. Validate the token + that the project you created actually exists.
if ! curl -fsS "https://app.launchdarkly.com/api/v2/projects/${LD_PROJECT_KEY}" \
      -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}" >/dev/null 2>&1; then
  fail-message "Couldn't find project '${LD_PROJECT_KEY}' with that token. Confirm the **project key** matches the one you created and that your token has the **Writer** role."
  exit 1
fi

# 3. Confirm the project has a 'test' environment (the app + checks use it).
if ! curl -fsS "https://app.launchdarkly.com/api/v2/projects/${LD_PROJECT_KEY}/environments/test" \
      -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}" >/dev/null 2>&1; then
  fail-message "Project '${LD_PROJECT_KEY}' has no **test** environment. Use a project with the default Test environment (or add one with key 'test')."
  exit 1
fi

# 4. Make token + project key available to later challenge scripts (idempotent).
for rc in "$HOME/.profile" "$HOME/.bashrc"; do
  touch "$rc"
  { grep -v -e '^export LD_PROJECT_KEY=' -e '^export LAUNCHDARKLY_ACCESS_TOKEN=' "$rc" || true; } > "$rc.tmp"
  mv "$rc.tmp" "$rc"
  printf 'export LD_PROJECT_KEY=%s\n' "$LD_PROJECT_KEY" >> "$rc"
  printf 'export LAUNCHDARKLY_ACCESS_TOKEN=%s\n' "$LAUNCHDARKLY_ACCESS_TOKEN" >> "$rc"
done

# 5. Restart so the app picks up the SDK key + AWS creds.
service togglewear restart

# 6. Bedrock smoke test on Haiku 4.5 (AWS_* are exported from .env above).
if ! "$VENV/bin/python" - "$HAIKU" <<'PY'
import os, sys, boto3
model = sys.argv[1]
c = boto3.client(
    "bedrock-runtime",
    region_name=os.environ.get("AWS_REGION", "us-east-1"),
    aws_access_key_id=os.environ["AWS_ACCESS_KEY_ID"],
    aws_secret_access_key=os.environ["AWS_SECRET_ACCESS_KEY"],
    aws_session_token=os.environ.get("AWS_SESSION_TOKEN") or None,
)
c.converse(
    modelId=model,
    messages=[{"role": "user", "content": [{"text": "hi"}]}],
    inferenceConfig={"maxTokens": 5},
)
PY
then
  fail-message "Your AWS credentials can't invoke Bedrock (Claude Haiku 4.5) in ${AWS_REGION:-us-east-1}. Confirm the keys are correct and that you've enabled Bedrock model access for Claude + Nova in your account's US regions."
  exit 1
fi

exit 0
