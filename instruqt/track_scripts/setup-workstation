#!/bin/bash
set -euo pipefail

until [ -f /opt/instruqt/bootstrap/host-bootstrap-completed ]; do
    echo "Waiting for instruqt bootstrap to complete"
    sleep 1
done

# BYO-credentials variant: there are NO shared secrets to inject. The learner
# pastes their own LaunchDarkly token + AWS creds in the Welcome challenge, and
# its Check provisions the project, fills in the SDK/project keys, and restarts
# the service. Here we only make sure a blank .env exists for them to edit.
APP_DIR=/opt/ld/ai-configs-intro/app
[ -f "$APP_DIR/.env" ] || cp "$APP_DIR/.env.example" "$APP_DIR/.env"

exit 0
