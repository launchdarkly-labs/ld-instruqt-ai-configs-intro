#!/bin/sh
#
# Challenge 06 is exploratory — the learner reads the monitoring view and
# answers reflective questions in their head. The only thing to verify is
# that the monitoring view actually has data to look at; if the traffic
# generator didn't land any events, the lab is broken.

METRICS=$(curl -s -X GET \
  "https://app.launchdarkly.com/api/v2/projects/${LD_PROJECT_KEY}/ai-configs/otto-assistant/metrics?env=test" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}")

# The metrics response includes a `generations` field; we check that it's
# non-zero so the monitoring view has something visible.
TOTAL=$(echo "$METRICS" | jq -r '.totalGenerations // .generationCount // 0')

if [ -z "$TOTAL" ] || [ "$TOTAL" = "null" ] || [ "$TOTAL" = "0" ]; then
  fail-message "The monitoring view has no data yet. Re-run setup, or run the traffic generator manually: \`/opt/ld/ai-configs-intro/app/.venv/bin/python /opt/ld/ai-configs-intro/traffic-generator/generate_traffic.py\`"
  exit 1
fi

exit 0
