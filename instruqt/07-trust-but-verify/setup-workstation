#!/bin/sh
#
# Pre-builds everything for the guarded-rollout lab: Nova Pro variation,
# judge AI Config, quality-score metric, and the server-side judge call.
# Starts a low-rate background traffic generator so the rollout has data
# to evaluate against while the learner sets it up.

set -e

REPO=/opt/ld/ai-configs-intro
VENV=$REPO/app/.venv

# 1. Apply Terraform — creates Nova Pro variation, judge config, metric,
#    and wires otto-assistant.evaluationMetricKey.
cd $REPO/terraform/challenge-07
echo "project_key = \"${LD_PROJECT_KEY}\"" > terraform.tfvars
terraform init -input=false
terraform apply -auto-approve

# 2. Patch server.py with the judge integration.
python3 $REPO/terraform/challenge-07/patch-server.py

# 3. Pick up the new code.
service togglewear restart

# 4. Start background traffic in the background so the rollout has organic
#    data. Logs to /var/log/togglewear-bg-traffic.log; kill with
#    `pkill -f background_traffic.py` if needed.
nohup "$VENV/bin/python" $REPO/traffic-generator/background_traffic.py \
  > /var/log/togglewear-bg-traffic.log 2>&1 &

exit 0
