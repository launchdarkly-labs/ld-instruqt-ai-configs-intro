#!/bin/sh

# 1. The otto-premium variation exists with the Sonnet 4.5 model config.
CONFIG=$(curl -s -X GET \
  "https://app.launchdarkly.com/api/v2/projects/${LD_PROJECT_KEY}/ai-configs/otto-assistant" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}")

PREMIUM_MODEL=$(echo "$CONFIG" | jq -r '.variations[]? | select(.key=="otto-premium") | .modelConfigKey // ""')
if [ -z "$PREMIUM_MODEL" ]; then
  fail-message "The premium variation hasn't been added yet. Create a new variation named **Otto v2 (Premium)** with key **otto-premium**."
  exit 1
fi
if [ "$PREMIUM_MODEL" != "Anthropic.claude-sonnet-4-5" ]; then
  fail-message "The premium variation isn't using Claude Sonnet 4.5. Pick **Anthropic Claude Sonnet 4.5** as the model."
  exit 1
fi

# 2. The variation has a system message.
PREMIUM_PROMPT=$(echo "$CONFIG" | jq -r '.variations[]? | select(.key=="otto-premium") | .messages[]? | select(.role=="system") | .content')
if [ -z "$PREMIUM_PROMPT" ] || [ "$PREMIUM_PROMPT" = "null" ]; then
  fail-message "The premium variation needs a system message. Add the premium-tier prompt from the lab."
  exit 1
fi

# 3. A targeting rule routes tier==premium to otto-premium.
TARGETING=$(curl -s -X GET \
  "https://app.launchdarkly.com/api/v2/projects/${LD_PROJECT_KEY}/ai-configs/otto-assistant/targeting" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}")

PREMIUM_VAR_ID=$(echo "$TARGETING" | jq -r '.variations[]? | select(.name=="Otto v2 (Premium)") | ._id')

# Look for a rule with a clause attribute=tier, op=in, values includes "premium",
# pointing at the premium variation (by index).
PREMIUM_RULE=$(echo "$TARGETING" | jq -r --arg pid "$PREMIUM_VAR_ID" '
  .environments.test.rules[]? as $r
  | select($r.clauses[]? | (.attribute=="tier" and (.values | index("premium"))))
  | $r._id
' | head -1)

if [ -z "$PREMIUM_RULE" ]; then
  fail-message "No targeting rule for **premium** users found. On the **Targeting** tab, add a rule like: \`user.tier is one of premium\` → **Otto v2 (Premium)**."
  exit 1
fi

# Confirm the rule serves the premium variation (by index)
RULE_VAR_IDX=$(echo "$TARGETING" | jq -r --arg rid "$PREMIUM_RULE" '
  .environments.test.rules[]? | select(._id==$rid) | .variation
')
RULE_VAR_ID=$(echo "$TARGETING" | jq -r --argjson idx "$RULE_VAR_IDX" '.variations[$idx]._id')
if [ "$RULE_VAR_ID" != "$PREMIUM_VAR_ID" ]; then
  fail-message "The premium targeting rule is serving the wrong variation. Make sure it routes to **Otto v2 (Premium)**."
  exit 1
fi

exit 0
