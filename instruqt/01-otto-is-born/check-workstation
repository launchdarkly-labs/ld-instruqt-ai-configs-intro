#!/bin/sh

# 1. The otto-assistant AI Config exists.
CONFIG=$(curl -s -X GET \
  "https://app.launchdarkly.com/api/v2/projects/${LD_PROJECT_KEY}/ai-configs/otto-assistant" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}")

if [ "$(echo "$CONFIG" | jq -r '.key // "null"')" = "null" ]; then
  fail-message "The Otto Assistant AI Config has not been created yet. Follow the steps under **Create Otto's AI Config**."
  exit 1
fi

# 2. The otto-born variation exists with a Haiku model config.
VARIATION_MODEL=$(echo "$CONFIG" | jq -r '.variations[]? | select(.key=="otto-born") | .modelConfigKey // ""')
if [ -z "$VARIATION_MODEL" ]; then
  fail-message "Otto's first variation is missing. Make sure you created the variation named **Otto v1 (Born)** with key **otto-born**."
  exit 1
fi
if [ "$VARIATION_MODEL" != "Anthropic.claude-haiku-4-5" ]; then
  fail-message "Otto's variation isn't using Claude Haiku 4.5. Pick **Anthropic Claude Haiku 4.5** as the model."
  exit 1
fi

# 3. The variation has a system message (don't assert specific wording yet —
#    that's challenge 02's concern).
SYSTEM_MSG=$(echo "$CONFIG" | jq -r '.variations[]? | select(.key=="otto-born") | .messages[]? | select(.role=="system") | .content' | head -c 1)
if [ -z "$SYSTEM_MSG" ]; then
  fail-message "Otto's variation needs a system message. Add the starter prompt from the lab instructions."
  exit 1
fi

# 4. Targeting in `test` env points at otto-born (not the default `disabled` variation).
TARGETING=$(curl -s -X GET \
  "https://app.launchdarkly.com/api/v2/projects/${LD_PROJECT_KEY}/ai-configs/otto-assistant/targeting" \
  -H "Authorization: ${LAUNCHDARKLY_ACCESS_TOKEN}")
BORN_NAME=$(echo "$CONFIG" | jq -r '.variations[]? | select(.key=="otto-born") | .name')
FALLTHROUGH_IDX=$(echo "$TARGETING" | jq -r '.environments.test.fallthrough.variation // empty')
FALLTHROUGH_NAME=$(echo "$TARGETING" | jq -r ".variations[${FALLTHROUGH_IDX}].name // empty")
if [ "$FALLTHROUGH_NAME" != "$BORN_NAME" ]; then
  fail-message "Otto's **test** environment isn't serving the Born variation. On the **Targeting** tab, set the default variation to **Otto v1 (Born)**."
  exit 1
fi

# 5. The learner has pasted the SDK code into server.py.
if ! grep -q 'ai_client.completion_config(OTTO_CONFIG_KEY' /opt/ld/ai-configs-intro/app/server.py; then
  fail-message "Your server code still has the placeholder. Replace the **Challenge 01 paste block** in \`server.py\` with the code from the lab."
  exit 1
fi

exit 0
